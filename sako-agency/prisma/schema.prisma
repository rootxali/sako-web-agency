generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  
  access_token       String?  
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  accounts      Account[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ContactRequest {
  id        String   @id @default(cuid())
  name      String
  email     String
  company   String?
  service   String
  budget    String?
  message   String
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
}

model BlogPost {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  excerpt   String?
  content   String?
  category  String?
  image     String?
  author    String?
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Service {
  id              String   @id @default(cuid())
  name            String
  tagline         String?
  description     String?
  icon            String?
  backgroundImage String?
  order           Int      @default(0)
  createdAt       DateTime @default(now())
}

model TeamMember {
  id        String   @id @default(cuid())
  name      String
  role      String?
  handle    String   @unique
  initials  String?
  bio       String?
  avatar    String?
  category  String?
  color     String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model WorkItem {
  id        String   @id @default(cuid())
  title     String
  category  String?
  services  String?
  year      String?
  url       String?
  image     String?
  gradient  String?
  accent    String?
  result    String?
  tag       String?
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
}
